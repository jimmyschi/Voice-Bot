# Twilio credentials
# Found at: console.twilio.com → main dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Deepgram API key (used for both speech-to-text and text-to-speech)
# Found at: console.deepgram.com → API Keys
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Anthropic API key
# Found at: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Optional: set this to your public server URL to skip ngrok
# WEBHOOK_URL=https://your-server.com

# Target phone number for test calls (do not change)
TARGET_NUMBER=+18054398008
